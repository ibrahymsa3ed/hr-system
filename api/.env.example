APP_NAME="HR System"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.example.com

# Supported app locales: en (English), ar (Arabic, RTL)
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_TIMEZONE=UTC

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Production target: managed MySQL 8 / MariaDB
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hr_system
DB_USERNAME=hr_app
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# S3-compatible object storage for employee photos & documents
# (DigitalOcean Spaces / Cloudflare R2 / AWS S3)
FILESYSTEM_CLOUD=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=fra1
AWS_BUCKET=hr-files
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Firebase Cloud Messaging (push notifications) — path to service account JSON
FCM_CREDENTIALS=storage/app/firebase/service-account.json

# Attendance / geofence defaults
GEOFENCE_DEFAULT_RADIUS_METERS=150
ATTENDANCE_MISSING_PUNCH_GRACE_MINUTES=30

VITE_APP_NAME="${APP_NAME}"
